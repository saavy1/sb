PORT=3000
NODE_ENV=development

# Database
DB_PATH=./db
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# Internal API key for K8s svc-to-svc (optional in dev)
INTERNAL_API_KEY=

# Kubernetes
K8S_NAMESPACE=game-servers

# Minecraft defaults
MC_DEFAULT_MEMORY=32Gi
MC_DEFAULT_PORT=25565
MC_STORAGE_CLASS=local-path
MC_STORAGE_SIZE=50Gi

OPS_SSH_USER=saavy
OPS_SSH_HOST=xxx.xx.xx.xx

# CurseForge API key (for modpack downloads)
CURSEFORGE_API_KEY=
# AI Provider: "openrouter" (default) or "local" (vLLM, Ollama, etc.)
# When local, set AI_LOCAL_MODEL to match what's loaded in your vLLM/Ollama instance.
# Use AI_MODELS to add extra models to the UI picker (format: "id:name:provider,...")
AI_PROVIDER=openrouter
AI_LOCAL_URL=http://localhost:8000/v1
AI_LOCAL_API_KEY=not-needed
AI_LOCAL_MODEL=meta-llama/Llama-3.3-70B-Instruct

OPENROUTER_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
GRAFANA_WEBHOOK_TOKEN=
GRAFANA_URL=http://kube-prometheus-stack-grafana.monitoring.svc.cluster.local
GRAFANA_API_KEY=

# Infisical (secret management)
INFISICAL_URL=http://infisical.infisical.svc.cluster.local:8080
INFISICAL_API_TOKEN=

# Discord bot things
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
ELYSIA_API_URL=http://localhost:3000